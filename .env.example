# ── PredEdge 邮件通知(scripts/scan-notify.ts / scripts/mailer.ts)──
# 复制为 .env.local 并填入真实值;.env / .env.local 已被 .gitignore 忽略。

# SMTP 服务器(默认 163;可换任意 SMTP 服务商)
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_SECURE=true

# SMTP 登录邮箱。163 要求 From 地址必须等于该账号,mailer 会自动处理。
MAIL_USER=your_account@163.com

# SMTP 授权码(不是登录密码)。163: 网页设置 → POP3/SMTP/IMAP → 开启服务并生成授权码。
# 绝不要把真实授权码提交进仓库。
MAIL_AUTH_CODE=your_smtp_auth_code_placeholder

# 收件人,默认等于 MAIL_USER,可留空
MAIL_TO=recipient@example.com

# 发件人显示名,默认 "PredEdge Scanner"
MAIL_FROM_NAME=PredEdge Scanner
